{
	"name": "java25-sqlite-template",
	"version": "1.0.0",
	"description": "Java 25 + SQLite + MyBatis template with a copied React frontend.",
	"type": "module",
	"author": "ugnoguchigxp <ugnoguchigxp@gmail.com>",
	"license": "MIT",
	"keywords": ["java", "sqlite", "mybatis", "react", "vite", "typescript"],
	"scripts": {
		"dev": "bun scripts/dev.ts",
		"dev:vite": "vite",
		"bootstrap": "bun scripts/bootstrap.ts",
		"seed:dev": "bun scripts/seed-dev.ts",
		"start": "bun scripts/start.ts",
		"smoke:start": "bun scripts/smoke-start.ts",
		"auth:create-admin": "bun scripts/auth-create-admin.ts",
		"db:migrate": "bun scripts/db-migrate.ts",
		"contract:check": "bun scripts/contract-check.ts",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint web shared scripts vite.config.ts vitest.config.ts playwright.config.ts",
		"format": "biome format --write web shared scripts vite.config.ts vitest.config.ts playwright.config.ts",
		"format:check": "biome format web shared scripts vite.config.ts vitest.config.ts playwright.config.ts",
		"build:web": "vite build",
		"build": "bun run build:web && ./gradlew --no-daemon bootJar",
		"verify": "bun scripts/verify.ts",
		"verify:e2e": "bun run test:e2e",
		"verify:all": "bun run verify && bun run verify:e2e",
		"verify:strict": "bun run verify"
	},
	"dependencies": {
		"@tanstack/react-query": "5.101.0",
		"@tanstack/react-router": "1.170.15",
		"@tanstack/react-table": "8.21.3",
		"lucide-react": "1.18.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-hook-form": "7.79.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@playwright/test": "1.61.1",
		"@tailwindcss/vite": "4.3.1",
		"@types/bun": "1.3.14",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"@vitest/coverage-v8": "4.1.8",
		"tailwindcss": "4.3.1",
		"typescript": "5.9.3",
		"vite": "8.0.16",
		"vitest": "4.1.8"
	},
	"overrides": {
		"esbuild": "0.28.1",
		"picomatch": "4.0.4",
		"postcss": "8.5.15",
		"vite": "8.0.16"
	}
}
