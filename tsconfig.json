{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "types": ["node", "bun", "vite/client"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./web/src/*"],
      "@web/*": ["./web/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "shared/**/*",
    "web/**/*",
    "scripts/**/*",
    "tests/**/*",
    "playwright.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-web"]
}
