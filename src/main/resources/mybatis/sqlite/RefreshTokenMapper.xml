<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.javastandard.db.mapper.RefreshTokenMapper">
  <resultMap id="RefreshTokenResultMap" type="com.example.javastandard.db.model.RefreshTokenRecord">
    <id property="id" column="id"/>
    <result property="tokenHash" column="token_hash"/>
    <result property="userId" column="user_id"/>
    <result property="expiresAt" column="expires_at"/>
    <result property="createdAt" column="created_at"/>
  </resultMap>

  <select id="findByHash" resultMap="RefreshTokenResultMap">
    SELECT id, token_hash, user_id, expires_at, created_at
    FROM refresh_tokens
    WHERE token_hash = #{tokenHash}
  </select>

  <insert id="insert" parameterType="com.example.javastandard.db.model.RefreshTokenRecord">
    INSERT INTO refresh_tokens(id, token_hash, user_id, expires_at, created_at)
    VALUES (#{id}, #{tokenHash}, #{userId}, #{expiresAt}, #{createdAt})
  </insert>

  <delete id="consumeIfUnexpired">
    DELETE FROM refresh_tokens
    WHERE token_hash = #{tokenHash} AND expires_at &gt; #{now}
  </delete>

  <delete id="deleteByHash">
    DELETE FROM refresh_tokens WHERE token_hash = #{tokenHash}
  </delete>

  <delete id="deleteExpired">
    DELETE FROM refresh_tokens WHERE expires_at &lt;= #{now}
  </delete>
</mapper>
